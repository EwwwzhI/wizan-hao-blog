{
  "name": "ewwwzhi-personal-site",
  "version": "2.4.0",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "astro": "astro",
    "sync": "astro sync",
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown --cache",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --cache",
    "toolbar:on": "astro preferences enable devToolbar",
    "toolbar:off": "astro preferences disable devToolbar",
    "postbuild": "pagefind --site dist --glob \"blogs/**/*.html\" --exclude-selectors \"pre\" --include-characters \"<>\" && node ./scripts/postbuild.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^9.37.0",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@iconify/json": "^2.2.464",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.7.2",
    "@typescript-eslint/parser": "^8.46.0",
    "@unocss/reset": "66.5.3",
    "astro": "^6.4.6",
    "astro-expressive-code": "^0.41.7",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.4.0",
    "html-entities": "^2.6.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^2.1.2",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-directive-sugar": "^2.0.0",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "unist-util-visit": "^5.1.0",
    "unocss": "66.5.3",
    "vfile": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
