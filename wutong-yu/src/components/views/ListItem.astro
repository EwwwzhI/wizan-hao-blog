---
import Link from '~/components/base/Link.astro'

import { withBasePath } from '~/utils/path'
import { formatDate } from '~/utils/datetime'

interface Props {
  collectionType: string
  idx: number
  postSlug?: string
  title: string
  tags?: string[]
  minutesRead?: number
  date: string | Date
  radio?: boolean
  video?: boolean
  platform?: string
  redirect?: string
}

const {
  collectionType,
  idx,
  postSlug,
  title,
  tags,
  minutesRead,
  date,
  video,
  radio,
  platform,
  redirect,
} = Astro.props
---

<div class="slide-enter" style={{ '--enter-stage': idx }} data-tags={tags}>
  <Link
    class:list={[
      'list-item',
      { 'list-item--with-tags': !!tags && tags.length > 0 },
    ]}
    href={redirect ? redirect : withBasePath(`/${collectionType}/${postSlug}/`)}
    external={redirect ? true : false}
    enableNewTabWarning={redirect ? true : false}
  >
    <span slot="title" class="list-item__title">{title}</span>
    <span slot="end" class="list-item__meta">
      {
        video && (
          <span
            u-i-ri-film-line
            class="list-item__icon flex-none op-50 align-middle"
            title="Provided in video"
            aria-label="Provided in video"
          />
        )
      }
      {
        radio && (
          <span
            u-i-ri-radio-line
            class="list-item__icon flex-none op-50 align-middle"
            title="Provided in radio"
            aria-label="Provided in radio"
          />
        )
      }
      <time
        class="list-item__time op-50 text-sm ws-nowrap"
        datetime={new Date(date).toISOString()}
      >
        {formatDate(date, false)}
      </time>
      {
        !!minutesRead && (
          <span class="list-item__muted op-40 text-sm ws-nowrap">
            · {minutesRead} min
          </span>
        )
      }
      {platform && (
        <span class="list-item__muted op-40 text-sm ws-nowrap">
          · {platform}
        </span>
      )}
      {
        tags && tags.length > 0 && (
          <>
            <span class="list-item__muted op-40 text-sm">· </span>
            <span class="list-item__tags op-40 text-sm ws-nowrap inner-x-scroll">
              {tags.join(' / ')}
            </span>
          </>
        )
      }
    </span>
  </Link>
</div>

<style>
  .list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    overflow: hidden;
    border-bottom: none !important;
    transition: opacity 0.3s ease-in-out;
  }

  .list-item--with-tags {
    flex-direction: column;
    align-items: flex-start;
  }

  .list-item__title {
    font-size: 1.125rem;
    line-height: 1.35;
  }

  .list-item__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    max-width: 100%;
    flex-wrap: wrap;
  }

  .list-item__icon {
    flex: none;
  }

  .list-item__tags {
    max-width: 100%;
  }

  @media (max-width: 767.9px) {
    .list-item {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
