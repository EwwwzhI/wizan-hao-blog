---
import TocItem from '~/components/toc/TocItem.astro'
import { generateToc } from '~/utils/toc'
import { FEATURES } from '~/config'

import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

const { toc } = FEATURES
if (!toc || (Array.isArray(toc) && !toc[0])) return
const { minHeadingLevel, maxHeadingLevel } = toc[1]
const specHeadings = generateToc(headings, minHeadingLevel, maxHeadingLevel)
---

{
  specHeadings.length > 0 && (
    <mobile-toc-control class="mobile-toc-control print:hidden">
      <button
        type="button"
        class="mobile-toc-control__toggle"
        aria-expanded="false"
        aria-controls="mobile-toc-panel"
        aria-label="Toggle table of contents"
        title="Table of contents"
      >
        <span u-i-ri-menu-line></span>
      </button>

      <nav
        id="mobile-toc-panel"
        class="mobile-toc-control__panel"
        aria-label="Table of contents"
        hidden
      >
        <div class="mobile-toc-control__header">Table of Contents</div>
        <ul class="mobile-toc-control__list">
          {specHeadings.map((heading) => (
            <TocItem {heading} />
          ))}
        </ul>
      </nav>
    </mobile-toc-control>
  )
}

<style>
  .mobile-toc-control {
    display: none;
  }

  @media (max-width: 1199.9px) {
    .mobile-toc-control {
      display: contents;
    }
  }

  .mobile-toc-control__toggle {
    position: fixed;
    right: 1.25rem;
    bottom: 4.75rem;
    z-index: 55;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 0;
    border-radius: 9999px;
    background: rgba(136, 136, 136, 0.2);
    color: var(--c-text);
    opacity: 0.55;
    backdrop-filter: blur(10px);
    transition:
      opacity 0.2s ease,
      background-color 0.2s ease;
  }

  :global(.dark) .mobile-toc-control__toggle {
    background: rgba(136, 136, 136, 0.38);
  }

  .mobile-toc-control__toggle:hover,
  .mobile-toc-control__toggle[aria-expanded='true'] {
    opacity: 0.92;
    background: rgba(136, 136, 136, 0.3);
  }

  :global(.dark) .mobile-toc-control__toggle:hover,
  :global(.dark) .mobile-toc-control__toggle[aria-expanded='true'] {
    background: rgba(136, 136, 136, 0.5);
  }

  .mobile-toc-control__panel {
    position: fixed;
    right: 1.25rem;
    bottom: 7.75rem;
    z-index: 54;
    display: flex;
    flex-direction: column;
    width: min(24rem, calc(100vw - 2rem));
    max-height: min(60vh, 32rem);
    overflow: hidden;
    border: 1px solid rgba(125, 125, 125, 0.18);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(16px);
  }

  .mobile-toc-control__panel[hidden] {
    display: none;
  }

  :global(.dark) .mobile-toc-control__panel {
    background: rgba(12, 12, 12, 0.88);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
  }

  .mobile-toc-control__header {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    min-height: 3.35rem;
    padding: 0.8rem 1.125rem 0.65rem;
    border-bottom: 1px solid rgba(125, 125, 125, 0.22);
    background: rgb(255, 255, 255);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--c-text);
  }

  :global(.dark) .mobile-toc-control__header {
    background: rgb(12, 12, 12);
  }

  .mobile-toc-control__list {
    flex: 1 1 auto;
    min-height: 0;
    margin-top: 0;
    overflow-y: auto;
    padding: 0.35rem 1.5rem 1rem;
  }

  .mobile-toc-control__list :global(ul) {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mobile-toc-control__list :global(li) {
    margin-top: 0.5rem;
    line-height: 1.55;
    list-style: none;
    padding-left: 0;
  }

  .mobile-toc-control__list :global(li::before) {
    content: none;
    display: none;
  }

  .mobile-toc-control__list :global(a) {
    display: block;
    border-bottom: 0;
    color: var(--c-text);
    opacity: 0.72;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .mobile-toc-control__list :global(a:hover),
  .mobile-toc-control__list :global([aria-current='true']) {
    opacity: 1;
  }

  .mobile-toc-control__list > :global(li > a) {
    font-weight: 600;
  }

  .mobile-toc-control__list > :global(li > ul > li > a) {
    padding-left: 1rem;
    font-size: 0.96em;
    font-weight: 500;
  }

  .mobile-toc-control__list > :global(li > ul > li > ul > li > a) {
    padding-left: 2rem;
    font-size: 0.92em;
    font-weight: 500;
  }
</style>

<script>
  class MobileTocControl extends HTMLElement {
    #toggle: HTMLButtonElement | null = null
    #panel: HTMLElement | null = null
    #onDocumentClick = (event: MouseEvent) => {
      if (!this.#panel || !this.#toggle) return
      const target = event.target as Node | null
      if (!target || this.contains(target)) return
      this.#close()
    }

    #onResize = () => {
      if (window.matchMedia('(min-width: 1200px)').matches) this.#close()
    }

    connectedCallback() {
      this.#toggle = this.querySelector('.mobile-toc-control__toggle')
      this.#panel = this.querySelector('.mobile-toc-control__panel')
      if (!this.#toggle || !this.#panel) return

      this.#toggle.addEventListener('click', this.#onToggle)
      document.addEventListener('click', this.#onDocumentClick)
      window.addEventListener('resize', this.#onResize)
    }

    disconnectedCallback() {
      this.#toggle?.removeEventListener('click', this.#onToggle)
      document.removeEventListener('click', this.#onDocumentClick)
      window.removeEventListener('resize', this.#onResize)
    }

    #onToggle = () => {
      if (!this.#toggle || !this.#panel) return
      const expanded = this.#toggle.getAttribute('aria-expanded') === 'true'
      expanded ? this.#close() : this.#open()
    }

    #open = () => {
      if (!this.#toggle || !this.#panel) return
      this.#toggle.setAttribute('aria-expanded', 'true')
      this.#panel.hidden = false
    }

    #close = () => {
      if (!this.#toggle || !this.#panel) return
      this.#toggle.setAttribute('aria-expanded', 'false')
      this.#panel.hidden = true
    }
  }

  if (!customElements.get('mobile-toc-control')) {
    customElements.define('mobile-toc-control', MobileTocControl)
  }
</script>
