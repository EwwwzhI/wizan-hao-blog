---
import { UI } from '~/config'

interface Props {
  idx?: number
  text: string
  needId?: boolean
  wide?: boolean
}

const { idx, text, needId = false, wide = false } = Astro.props
const { maxGroupColumns } = UI.groupView
const slug = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
---

<div
  {...needId ? { id: slug(text) } : {}}
  class={`categorizer toc-heading relative h-20
    pointer-events-none select-none
    ${wide ? 'categorizer--wide' : ''}
    ${idx !== undefined ? 'slide-enter' : ''}`}
  style={{
    ...(idx !== undefined ? { '--enter-stage': idx - 2 } : {}),
    '--wide-left': maxGroupColumns === 3 ? '-1rem' : '14%',
  }}
>
  {
    !wide ? (
      <span class="categorizer__label">
        {text}
      </span>
    ) : (
      <span class="categorizer__label">
        {text}
      </span>
    )
  }
</div>

<style>
  .categorizer {
    position: relative;
    height: 2rem;
    pointer-events: none;
    user-select: none;
  }

  .categorizer__label {
    position: absolute;
    left: -3rem;
    top: -2rem;
    color: transparent;
    font-size: 8em;
    font-weight: 700;
    opacity: 0.1;
    -webkit-text-stroke: 2px #aaa;
    line-height: 1;
  }

  .categorizer--wide .categorizer__label {
    top: -1.5rem;
    left: var(--wide-left);
    font-size: 5em;
    opacity: 0.35;
    -webkit-text-stroke-width: 1.5px;
  }

  :global(.dark) .categorizer--wide .categorizer__label {
    opacity: 0.2;
  }

  @media (max-width: 1023.9px) {
    .categorizer--wide .categorizer__label {
      left: -1rem;
      font-size: 4.5em;
    }
  }

  @media (max-width: 767.9px) {
    .categorizer--wide .categorizer__label {
      top: 0.5rem;
      font-size: 3.6em;
    }
  }
</style>
