---
import TocSidebar from '~/components/toc/TocSidebar.astro'
import { FEATURES } from '~/config'

import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
}

const { headings } = Astro.props

const { toc } = FEATURES
const tocPosition = Array.isArray(toc) && toc[0] && toc[1].displayPosition
const tocDisplayMode = Array.isArray(toc) && toc[0] && toc[1].displayMode
---

{
  headings.length > 0 && (
    <aside id="desktop-aside" class="desktop-aside" data-position={tocPosition}>
      <button
        type="button"
        class="desktop-aside__trigger"
        aria-label="Table of contents"
        title="Table of contents"
        data-display-mode={tocDisplayMode}
      >
        TOC
      </button>
      <TocSidebar headings={headings} />
    </aside>
  )
}

<style>
  .desktop-aside {
    --desktop-toc-width: 12rem;
    position: fixed;
    top: 8.875rem;
    z-index: 100;
    left: calc(100vw - var(--desktop-toc-width) - 3.2rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .desktop-aside[data-position='left'] {
    left: 2rem;
  }

  .desktop-aside__trigger {
    display: flex;
    align-items: center;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--c-text);
    font-size: var(--blog-reading-size);
    font-weight: 500;
    opacity: 0.55;
    transition: opacity 0.7s ease-in-out;
  }

  .desktop-aside__trigger[data-display-mode='always'] {
    opacity: 0.82;
  }

  .desktop-aside:hover .desktop-aside__trigger[data-display-mode='hover'],
  :global(.slide-enter-content:hover)
    .desktop-aside__trigger[data-display-mode='content'],
  :global(.group\/content:hover)
    .desktop-aside__trigger[data-display-mode='content'] {
    opacity: 0.82;
  }

  @media (max-width: 1199.9px) {
    .desktop-aside {
      display: none;
    }
  }
</style>
