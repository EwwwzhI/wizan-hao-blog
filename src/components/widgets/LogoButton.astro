---
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'
import { SITE } from '~/config'
---

<Link
  class="select-none op-transition"
  href={withBasePath('/')}
  aria-label={SITE.author}
  aria-current={Astro.url.pathname === `${withBasePath('/')}` ? 'page' : false}
>
  <div class="logo-container">
    <img
      class="logo-icon img-light"
      src={withBasePath('/cat-icon-2.svg')}
      alt=""
      aria-hidden="true"
    />
    <img
      class="logo-icon img-dark"
      src={withBasePath('/cat-icon.svg')}
      alt=""
      aria-hidden="true"
    />
  </div>
</Link>

<style>
  .logo-container {
    display: flex;
    justify-content: center;
    align-items: center;
    transform: scale(1.05);
  }

  @media (max-width: 767.9px) {
    .logo-container {
      margin-top: 0.125rem;

      transform-origin: 0%;
      transform: scale(0.95);
    }
  }

  .logo-icon {
    width: 3rem;
    height: 3rem;
    display: block;
    object-fit: cover;
  }

  .img-dark {
    display: none;
  }

  :global(html.dark) .img-light {
    display: none;
  }

  :global(html.dark) .img-dark {
    display: block;
  }
</style>
