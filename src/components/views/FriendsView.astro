---
import Link from '~/components/base/Link.astro'
import { getGroupedFriendsByCategory } from '~/utils/data'

function getInitial(name: string) {
  return name.trim().charAt(0).toUpperCase() || '?'
}

const groups = await getGroupedFriendsByCategory('friends')
const isEmpty = groups.length === 0
---

<section class="friends-page">
  {
    isEmpty ? (
      <section class="friends-shell slide-enter">
        <div class="friends-empty">
          <span class="friends-chip">Friends</span>
          <h2>友链系统已经接入完成</h2>
          <p>
            当前还没有友链数据，直接编辑 <code>src/content/friends/data.json</code>{' '}
            即可开始添加站点卡片。
          </p>
        </div>

        <aside class="friends-apply">
          <div class="friends-apply__head">
            <span class="friends-chip">申请友链</span>
            <h3>来信即可</h3>
          </div>
          <p class="friends-apply__copy">
            如果你也想把站点放到这里，把站点名称、链接、头像和一句话描述发到我的邮箱。
          </p>
          <a class="friends-apply__mail" href="mailto:15088484799@163.com">
            15088484799@163.com
          </a>
        </aside>
      </section>
    ) : (
      <section class="friends-shell slide-enter">
        <div class="friends-board">
          <div class="friends-groups">
            {groups.map((group) => (
              <section class="friends-group">
                <header class="friends-group__header">
                  <div class="friends-group__title-wrap">
                    <span class="friends-chip">{group.category}</span>
                    <p class="friends-group__meta">{group.items.length} 个站点</p>
                  </div>
                </header>

                <div class="friends-grid">
                  {group.items.map((item) => (
                    <Link
                      href={item.data.link}
                      external={true}
                      class="friend-card"
                      title={item.data.desc}
                    >
                      <div class="friend-card__avatar-wrap" aria-hidden="true">
                        {item.data.avatar ? (
                          <img
                            class="friend-card__avatar"
                            src={item.data.avatar}
                            alt=""
                            loading="lazy"
                            decoding="async"
                            referrerpolicy="no-referrer"
                          />
                        ) : (
                          <span class="friend-card__avatar-fallback">
                            {getInitial(item.data.name)}
                          </span>
                        )}
                      </div>

                      <div class="friend-card__body">
                        <div class="friend-card__topline">
                          <h3>{item.data.name}</h3>
                        </div>

                        {item.data.siteLabel && (
                          <p class="friend-card__label">{item.data.siteLabel}</p>
                        )}

                        <p class="friend-card__desc">{item.data.desc}</p>
                      </div>
                    </Link>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>

        <aside class="friends-apply">
          <div class="friends-apply__head">
            <span class="friends-chip">申请友链</span>
            <h3>来信即可</h3>
          </div>
          <p class="friends-apply__copy">
            如果你也希望出现在这里，把站点名称、链接、头像和一句话描述发到我的邮箱。
          </p>
          <a class="friends-apply__mail" href="mailto:15088484799@163.com">
            15088484799@163.com
          </a>
          <p class="friends-apply__hint">
            建议顺手附上站点简介，方便我直接整理成卡片。
          </p>
        </aside>
      </section>
    )
  }
</section>

<style>
  .friends-page {
    width: min(68vw, 90rem);
    max-width: 100%;
    margin: -1.6rem auto 0;
    --friends-shell-bg: color-mix(in srgb, var(--c-bg) 97%, var(--c-text) 3%);
    --friends-panel-bg: color-mix(in srgb, var(--c-bg) 98%, var(--c-text) 2%);
    --friends-card-bg: color-mix(in srgb, var(--c-bg) 99%, var(--c-text) 1%);
    --friends-card-hover: color-mix(in srgb, var(--c-bg) 93%, var(--c-text) 7%);
    --friends-border: color-mix(in srgb, var(--c-text) 10%, transparent);
    --friends-border-strong: color-mix(in srgb, var(--c-text) 18%, transparent);
    --friends-muted: color-mix(in srgb, var(--c-text) 60%, transparent);
    --friends-subtle: color-mix(in srgb, var(--c-text) 44%, transparent);
    --friends-avatar-ring: color-mix(in srgb, var(--c-bg) 90%, transparent);
  }

  :global(.dark) .friends-page {
    --friends-shell-bg: color-mix(in srgb, var(--c-bg) 91%, var(--c-text) 9%);
    --friends-panel-bg: color-mix(in srgb, var(--c-bg) 93%, var(--c-text) 7%);
    --friends-card-bg: color-mix(in srgb, var(--c-bg) 94%, var(--c-text) 6%);
    --friends-card-hover: color-mix(in srgb, var(--c-bg) 87%, var(--c-text) 13%);
    --friends-border: color-mix(in srgb, var(--c-text) 14%, transparent);
    --friends-border-strong: color-mix(in srgb, var(--c-text) 24%, transparent);
    --friends-muted: color-mix(in srgb, var(--c-text) 68%, transparent);
    --friends-subtle: color-mix(in srgb, var(--c-text) 48%, transparent);
    --friends-avatar-ring: color-mix(in srgb, var(--c-bg) 84%, transparent);
  }

  .friends-shell {
    display: grid;
    gap: 1.25rem;
  }

  .friends-board,
  .friends-apply,
  .friends-empty {
    padding: 1.35rem 1.35rem 1.45rem;
    border: 1px solid var(--friends-border);
    border-radius: 1.8rem;
    background: var(--friends-shell-bg);
  }

  .friends-board {
    display: grid;
    gap: 0.35rem;
  }

  .friends-groups {
    display: grid;
    gap: 0;
  }

  .friends-group {
    padding: 1.05rem 0.15rem 0.2rem;
  }

  .friends-group__header {
    margin-bottom: 1rem;
  }

  .friends-group__title-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem;
  }

  .friends-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.2rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--friends-border);
    color: var(--friends-subtle);
    background: color-mix(in srgb, var(--c-bg) 86%, transparent);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .friends-group__meta {
    margin: 0;
    color: var(--friends-muted);
    font-size: 0.92rem;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .friend-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    min-height: 6.9rem;
    padding: 0.95rem 1rem;
    border: 1px solid var(--friends-border);
    border-radius: 1.15rem;
    background: var(--friends-card-bg);
    color: inherit;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      opacity 180ms ease;
  }

  .friend-card:hover {
    transform: translateY(-1px);
    border-color: var(--friends-border-strong);
    background: var(--friends-card-hover);
  }

  .friend-card__avatar-wrap {
    position: relative;
    width: 3.7rem;
    height: 3.7rem;
    flex: none;
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-bg) 88%, var(--c-text) 12%);
    box-shadow: 0 0 0 0.28rem var(--friends-avatar-ring);
    overflow: hidden;
  }

  .friend-card__avatar {
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
    border-radius: inherit;
    object-fit: cover;
    object-position: center;
  }

  .friend-card__avatar-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
  }

  .friend-card__avatar-fallback {
    font-size: 1.35rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--c-text) 78%, transparent);
  }

  .friend-card__body {
    min-width: 0;
  }

  .friend-card__topline {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .friend-card__topline h3 {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 1.02rem;
    line-height: 1.35;
    color: color-mix(in srgb, var(--c-text) 92%, transparent);
  }

  .friend-card__label,
  .friend-card__desc,
  .friends-apply__copy,
  .friends-apply__hint,
  .friends-empty p,
  .friends-empty h2 {
    margin: 0;
  }

  .friend-card__label {
    margin-top: 0.35rem;
    color: var(--friends-subtle);
    font-size: 0.84rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .friend-card__desc {
    display: -webkit-box;
    margin-top: 0.32rem;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    color: var(--friends-muted);
    font-size: 0.9rem;
    line-height: 1.52;
  }

  .friends-empty {
    display: grid;
    gap: 0.85rem;
    justify-items: start;
    padding: 1.6rem;
  }

  .friends-empty h2 {
    font-size: 1.2rem;
    color: color-mix(in srgb, var(--c-text) 92%, transparent);
  }

  .friends-empty p {
    color: var(--friends-muted);
    line-height: 1.7;
  }

  .friends-empty code {
    padding: 0.08rem 0.4rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--c-text) 8%, transparent);
    font-size: 0.92em;
  }

  .friends-apply {
    display: grid;
    gap: 0.75rem;
    background: var(--friends-panel-bg);
  }

  .friends-apply__head {
    display: grid;
    gap: 0.55rem;
  }

  .friends-apply__head h3 {
    margin: 0;
    font-size: 1.14rem;
    color: color-mix(in srgb, var(--c-text) 92%, transparent);
  }

  .friends-apply__copy,
  .friends-apply__hint {
    color: var(--friends-muted);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .friends-apply__mail {
    width: fit-content;
    padding: 0.42rem 0.78rem;
    border: 1px solid var(--friends-border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-bg) 86%, transparent);
    color: color-mix(in srgb, var(--c-text) 86%, transparent);
    font-size: 0.95rem;
  }

  .friends-apply__mail:hover {
    border-color: var(--friends-border-strong);
  }

  @media (max-width: 1480px) {
    .friends-page {
      width: min(74vw, 86rem);
    }

    .friends-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 1180px) {
    .friends-page {
      width: min(82vw, 76rem);
    }

    .friends-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .friends-page {
      width: 100%;
    }

    .friends-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .friends-page {
      width: 100%;
    }

    .friends-board,
    .friends-apply,
    .friends-empty {
      padding: 1rem;
      border-radius: 1.25rem;
    }

    .friends-grid {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .friend-card {
      min-height: 6.5rem;
      padding: 0.92rem;
      border-radius: 1rem;
    }

    .friend-card__avatar-wrap {
      width: 3.3rem;
      height: 3.3rem;
      box-shadow: 0 0 0 0.22rem var(--friends-avatar-ring);
    }

    .friends-group {
      padding-inline: 0;
    }
  }
</style>
