---
import { render } from 'astro:content'

import Link from '~/components/base/Link.astro'
import { getGroupedInsightsByYear } from '~/utils/data'

const CONTENT_PREVIEW_LIMIT = 200

function formatDate(value: Date) {
  return value.toISOString().slice(0, 10).replaceAll('-', '.')
}

function stripMarkdown(content: string) {
  return content
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/[`*_>#~-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
}

function getPreview(content: string) {
  const plain = stripMarkdown(content)
  return plain.length > CONTENT_PREVIEW_LIMIT
    ? `${plain.slice(0, CONTENT_PREVIEW_LIMIT).trim()}...`
    : plain
}

const rawGroups = await getGroupedInsightsByYear('insights')

const insightGroups = await Promise.all(
  rawGroups.map(async (group, groupIndex) => ({
    year: group.year,
    toggleId: `insights-year-toggle-${group.year}`,
    defaultOpen: groupIndex === 0,
    items: await Promise.all(
      group.items.map(async (item) => {
        const { Content } = await render(item.entry)
        const body = item.body ?? ''
        const preview = getPreview(body)
        const isTruncated = stripMarkdown(body).length > CONTENT_PREVIEW_LIMIT

        return {
          ...item,
          Content,
          preview,
          isTruncated,
        }
      })
    ),
  }))
)
---

<section class="insights-page">
  <div class="insights-timeline">
    {insightGroups.map((group) => (
      <section class="insights-year">
        <input
          id={group.toggleId}
          class="insights-year__state"
          type="checkbox"
          checked={group.defaultOpen}
        />
        <div class="insights-year__header">
          <div class="insights-year__heading">
            <p class="insights-year__label">{group.year}</p>
            <p class="insights-year__meta">{group.items.length} 条记录</p>
          </div>
          <label
            for={group.toggleId}
            class="insights-year__toggle"
            aria-label={`${group.defaultOpen ? '收起' : '展开'} ${group.year} 年的记录`}
          >
            <span class="insights-year__toggle-text insights-year__toggle-text--closed">
              展开
            </span>
            <span class="insights-year__toggle-text insights-year__toggle-text--open">
              收起
            </span>
          </label>
        </div>

        <div class="insights-year__body">
          <ul class="insights-year__list">
            {group.items.map((item) => (
              <li class="insight-node">
                <span class="insight-node__dot" aria-hidden="true" />

                <div
                  class:list={[
                    'insight-node__grid',
                    { 'insight-node__grid--text-only': !item.data.image },
                  ]}
                >
                  <section class="insight-node__text">
                    <div class="insight-node__meta">
                      <span>{formatDate(item.data.pubDate)}</span>
                      <span>{item.data.category}</span>
                    </div>

                    <h2>{item.data.title}</h2>

                    {(item.data.author || item.data.sourceUrl) && (
                      <p class="insight-node__source">
                        <span class="insight-node__source-mark" aria-hidden="true">
                          —
                        </span>
                        {item.data.sourceUrl ? (
                          <Link
                            href={item.data.sourceUrl}
                            class="insight-node__source-link"
                            external={true}
                          >
                            {item.data.author || 'Source'}
                          </Link>
                        ) : (
                          <span class="insight-node__source-author">
                            {item.data.author}
                          </span>
                        )}
                      </p>
                    )}

                    {item.isTruncated ? (
                      <details class="insight-copy">
                        <summary class="insight-copy__summary">
                          <span class="insight-copy__summary-text insight-copy__summary-text--closed">
                            展开全文
                          </span>
                          <span class="insight-copy__summary-text insight-copy__summary-text--open">
                            收起内容
                          </span>
                        </summary>
                        <p class="insight-copy__preview">{item.preview}</p>
                        <div class="insight-copy__full">
                          <item.Content />
                        </div>
                      </details>
                    ) : (
                      <div class="insight-node__content">
                        <item.Content />
                      </div>
                    )}
                  </section>

                  {item.data.image && (
                    <figure class="insight-node__media">
                      <img
                        src={item.data.image}
                        alt={item.data.imageAlt || item.data.title}
                        loading="lazy"
                      />
                    </figure>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))}
  </div>
</section>

<style>
  .insights-page {
    position: relative;
    width: 100%;
    max-width: none;
    padding: 0 0 4rem;
    color: color-mix(in srgb, var(--c-text) 90%, transparent);
    background: transparent;
  }

  .insights-timeline {
    display: grid;
    gap: 4rem;
  }

  .insights-year {
    display: grid;
    gap: 1.5rem;
  }

  .insights-year__state {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    border: 0;
    white-space: nowrap;
  }

  .insights-year__header {
    min-width: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 1rem 2rem;
  }

  .insights-year__body {
    position: relative;
    padding-top: 1rem;
  }

  .insights-year__heading {
    display: grid;
    min-width: 0;
    gap: 0.55rem;
  }

  .insights-year__label {
    margin: 0;
    color: transparent;
    font-size: clamp(4.25rem, 12vw, 7.5rem);
    font-weight: 700;
    line-height: 0.86;
    letter-spacing: -0.07em;
    opacity: 0.28;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--c-text) 38%, transparent);
  }

  :global(.dark) .insights-year__label {
    opacity: 0.18;
  }

  .insights-year__meta {
    margin: 0;
    padding-left: 0.2rem;
    font-size: 0.92rem;
    letter-spacing: 0.02em;
    opacity: 0.52;
  }

  .insights-year__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: end;
    min-width: 3em;
    padding: 0;
    margin-bottom: -0.2rem;
    font-size: 0.92rem;
    opacity: 0.56;
    cursor: pointer;
  }

  .insights-year__toggle-text--open,
  .insights-year__state:checked
    ~ .insights-year__header
    .insights-year__toggle-text--closed {
    display: none;
  }

  .insights-year__state:checked
    ~ .insights-year__header
    .insights-year__toggle-text--open {
    display: inline;
  }

  .insights-year__list {
    grid-area: list;
    display: grid;
    gap: 3rem;
    margin: 0;
    padding: 0 0 0 2.35rem;
    list-style: none;
  }

  .insights-year__state:not(:checked) ~ .insights-year__body {
    display: none;
  }

  .insights-year__list::before {
    content: '';
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: 0.55rem;
    width: 1px;
    background: color-mix(in srgb, var(--c-text) 14%, transparent);
  }

  .insight-node {
    position: relative;
  }

  .insight-node__dot {
    position: absolute;
    top: 0.55rem;
    left: -2.35rem;
    width: 0.9rem;
    height: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--c-text) 22%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-bg) 96%, transparent);
    box-shadow: 0 0 0 0.28rem color-mix(in srgb, var(--c-bg) 96%, transparent);
  }

  .insight-node__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(22rem, 0.95fr);
    gap: clamp(1.75rem, 3vw, 3.5rem);
    align-items: start;
  }

  .insight-node__text {
    min-width: 0;
    max-width: 52rem;
  }

  .insight-node__grid--text-only {
    grid-template-columns: minmax(0, 1fr);
  }

  .insight-node__text h2 {
    margin: 0;
    font-family: 'WoHuiBaNiJiaoZuoAiQing-2', sans-serif;
    font-weight: 400;
    font-synthesis: none;
    font-size: clamp(2.15rem, 1.7vw, 1.55rem);
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .insight-node__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 0.9rem;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.46;
  }

  .insight-copy__preview,
  .insight-node__content :global(p),
  .insight-copy__full :global(p) {
    margin: 1rem 0 0;
    font-size: 1.02rem;
    line-height: 1.95;
    opacity: 0.84;
  }

  .insight-node__content :global(p:first-child),
  .insight-copy__full :global(p:first-child) {
    margin-top: 1rem;
  }

  .insight-node__content :global(p + p),
  .insight-copy__full :global(p + p) {
    margin-top: 0.85rem;
  }

  .insight-copy {
    display: flex;
    flex-direction: column;
  }

  .insight-copy__summary {
    order: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    width: fit-content;
    margin-top: 1rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.94rem;
    opacity: 0.62;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .insight-copy__summary:hover {
    opacity: 0.9;
    transform: translateX(2px);
  }

  .insight-copy__summary::-webkit-details-marker {
    display: none;
  }

  .insight-copy__summary-text--open,
  .insight-copy[open] .insight-copy__summary-text--closed,
  .insight-copy[open] .insight-copy__preview {
    display: none;
  }

  .insight-copy[open] .insight-copy__summary-text--open,
  .insight-copy[open] .insight-copy__full {
    display: block;
  }

  .insight-copy__full {
    display: none;
  }

  .insight-node__source {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.65rem;
    margin-bottom: 0.35rem;
    padding: 0.15rem 0 0.25rem;
    justify-content: flex-end;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.02rem;
    line-height: 1.95;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--c-text) 54%, transparent);
  }

  .insight-node__source-mark {
    font-size: 0.95rem;
    line-height: 1;
    opacity: 0.34;
    transform: translateY(-0.01rem);
  }

  .insight-node__source-author {
    font-style: italic;
    opacity: 0.82;
  }

  .insight-node__source-link {
    text-decoration: none;
    font-style: italic;
    opacity: 0.76;
    border-bottom: 1px solid transparent;
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      border-color 180ms ease;
  }

  .insight-node__source-link:hover {
    opacity: 1;
    transform: translateX(2px);
    border-color: currentColor;
  }

  .insight-node__media {
    position: relative;
    margin: 0;
    overflow: hidden;
    border-radius: 1.65rem;
    background: color-mix(in srgb, var(--c-bg) 96%, var(--c-text) 4%);
  }

  .insight-node__media::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 32%;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.14));
    pointer-events: none;
  }

  .insight-node__media img {
    display: block;
    width: 100%;
    aspect-ratio: 5 / 3.6;
    object-fit: cover;
    opacity: 0.96;
  }

  @media (max-width: 1100px) {
    .insights-year {
      gap: 1rem;
    }

    .insights-year__header {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .insights-year__toggle {
      justify-content: flex-start;
      margin-bottom: 0;
    }

    .insights-year__body {
      padding-top: 0.8rem;
    }

    .insight-node__grid {
      grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.92fr);
    }
  }

  @media (max-width: 900px) {
    .insight-node__grid {
      grid-template-columns: 1fr;
      gap: 1.35rem;
    }

    .insight-node__media {
      max-width: min(100%, 42rem);
    }
  }

  @media (max-width: 640px) {
    .insights-page {
      padding-bottom: 2rem;
    }

    .insights-year__heading {
      gap: 0.35rem;
    }

    .insights-year__list {
      gap: 2.2rem;
      padding-left: 1.5rem;
    }

    .insights-year__list::before {
      left: 0.32rem;
    }

    .insight-node__dot {
      left: -1.5rem;
      width: 0.8rem;
      height: 0.8rem;
      box-shadow: 0 0 0 0.18rem color-mix(in srgb, var(--c-bg) 96%, transparent);
    }

    .insight-copy__preview,
    .insight-node__content :global(p),
    .insight-copy__full :global(p) {
      font-size: 0.98rem;
      line-height: 1.85;
    }

    .insight-node__source {
      justify-content: flex-start;
      font-size: 0.98rem;
    }

    .insight-node__media {
      border-radius: 1.3rem;
    }
  }
</style>
